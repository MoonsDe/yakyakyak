<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="@color/divider"
    app:cardBackgroundColor="@color/card_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- 상태 인디케이터 바 -->
        <View
            android:id="@+id/view_status_bar"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="#6C63FF"
            android:layout_marginEnd="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- 약 아이콘 -->
        <TextView
            android:id="@+id/tv_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="💊"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/bg_icon_circle"
            app:layout_constraintStart_toEndOf="@id/view_status_bar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- 가운데 콘텐츠 영역 -->
        <LinearLayout
            android:id="@+id/layout_center"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/tv_icon"
            app:layout_constraintEnd_toStartOf="@id/checkbox_taken"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- 약 이름 -->
            <TextView
                android:id="@+id/tv_medication_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <!-- 복용 시간 (복용 방법 포함) -->
            <TextView
                android:id="@+id/tv_scheduled_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:layout_marginTop="2dp" />

            <!-- 복용 완료 시간 or 식사 알람 설정 안내 -->
            <TextView
                android:id="@+id/tv_taken_at"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/success"
                android:visibility="gone"
                android:layout_marginTop="2dp" />

            <!-- 식사 완료 버튼 (식후 약인 경우만 표시) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_meal_done"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="🍽️ 식사 완료"
                android:textSize="11sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:visibility="gone"
                android:layout_marginTop="6dp"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/primary_light"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp" />

        </LinearLayout>

        <!-- 복용 완료 체크박스 -->
        <CheckBox
            android:id="@+id/checkbox_taken"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/primary"
            android:scaleX="1.2"
            android:scaleY="1.2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
